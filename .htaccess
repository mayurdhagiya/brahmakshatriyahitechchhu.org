# =============================================================
#  Brahmakshatriya Hitechchhu - Apache configuration
#  -------------------------------------------------------------
#  DORMANT ON GITHUB PAGES. GitHub Pages does NOT read .htaccess,
#  so on the current host this file does nothing. It is kept as a
#  ready-made fallback in case the site ever migrates to Apache
#  (cPanel / shared hosting).
#
#  The live redirects on GitHub Pages are handled client-side by
#  js/redirects.js - keep the two in sync if you edit either.
# =============================================================

# ---- Force HTTPS -------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ---- Redirects (mirror of js/redirects.js) ----------------------
# Lower-case month aliases -> canonical capitalised, abbreviated folders.
Redirect 301 /editions/jan-2025/  /editions/Jan-2025/
Redirect 301 /editions/feb-2025/  /editions/Feb-2025/
Redirect 301 /editions/mar-2025/  /editions/Mar-2025/
Redirect 301 /editions/apr-2025/  /editions/Apr-2025/
Redirect 301 /editions/may-2025/  /editions/May-2025/
Redirect 301 /editions/june-2025/ /editions/Jun-2025/
Redirect 301 /editions/july-2025/ /editions/Jul-2025/
Redirect 301 /editions/aug-2025/  /editions/Aug-2025/
Redirect 301 /editions/sep-2025/  /editions/Sep-2025/
Redirect 301 /editions/oct-2025/  /editions/Oct-2025/
Redirect 301 /editions/nov-2025/  /editions/Nov-2025/
Redirect 301 /editions/dec-2025/  /editions/Dec-2025/

# Common typos / legacy paths.
Redirect 301 /trustee.html /trustees.html
Redirect 301 /about-us     /about.html
Redirect 301 /contact-us   /contact.html

# ---- Custom error page ------------------------------------------
ErrorDocument 404 /404.html

# ---- Caching ----------------------------------------------------
# HTML: always revalidate so content updates land immediately.
# CSS/JS/images: cache for 1 year - they are cache-busted via ?v=.
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
  <FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot|ico|pdf|mp3|ogg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# ---- Compression ------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml
</IfModule>
